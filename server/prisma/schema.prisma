generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      String   @default("MANAGER") // ADMIN, MANAGER, ACCOUNTANT, COURIER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requests  Request[]
}

model Company {
  id              String   @id @default(uuid())
  name            String
  bin             String   @unique
  address         String
  factAddress     String   @default("")
  phone           String   @default("")
  director        String   @default("")
  email           String   @default("")
  bank            String   @default("")
  bik             String   @default("")
  account         String   @default("")
  kbe             String   @default("")
  bankDetails     String   @default("")
  managerDetails  String   @default("")
  logo            String?  // Base64 logo
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  requests        Request[]
}

model Request {
  id          String   @id @default(uuid())
  status      String   @default("Заявка")
  date        String
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  managerId   Int
  manager     User     @relation(fields: [managerId], references: [id])
  type        String   @default("REQUEST")
  route       String?
  cargo       String?
  docNumber   String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  details     String?
}

model Contract {
  id           String   @id @default(uuid())
  number       String
  date         String
  type         String
  status       String   @default("active")
  companyId    String
  companyName  String?
  customerName String?
  actId        String?
  details      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
