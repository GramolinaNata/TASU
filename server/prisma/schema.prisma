generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  name      String
  role      String    @default("MANAGER")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  requests  Request[]
}

model Company {
  id             String    @id @default(uuid())
  name           String
  bin            String    @unique
  address        String
  factAddress    String    @default("")
  phone          String    @default("")
  director       String    @default("")
  email          String    @default("")
  bank           String    @default("")
  bik            String    @default("")
  account        String    @default("")
  kbe            String    @default("")
  bankDetails    String    @default("")
  managerDetails String    @default("")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  logo           String?
  requests       Request[]
}

model Request {
  id        String   @id @default(uuid())
  status    String   @default("Заявка")
  date      String
  companyId String
  managerId Int
  type      String   @default("REQUEST")
  route     String?
  cargo     String?
  docNumber String?  @unique
  totalSum  String?  @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  details   String?
  company   Company  @relation(fields: [companyId], references: [id])
  manager   User     @relation(fields: [managerId], references: [id])
}

model Contract {
  id             String   @id @default(uuid())
  number         String
  date           String
  type           String
  status         String   @default("active")
  companyId      String
  companyName    String?
  customerName   String?
  actId          String?
  details        String?
  counterpartyId String?
  directorName   String?
  directorPosition String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Counterparty {
  id          String   @id @default(uuid())
  name        String
  phone       String   @default("")
  email       String   @default("")
  companyName String   @default("")
  bin         String   @default("")
  address     String   @default("")
  bank        String   @default("")
  bik         String   @default("")
  account     String   @default("")
  kbe         String   @default("")
  director    String   @default("")
  companyId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}



model Expense {
  id          String   @id @default(uuid())
  date        String
  category    String
  description String   @default("")
  amount      Float
  docNumber   String   @default("")
  companyId   String?
  userId      Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tariff {
  id           String   @id @default(uuid())
  city         String   @unique
  pricePerKg   Float    @default(0)
  deliveryPrice Float   @default(0)
  companyId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}


model Batch {
  id             String   @id @default(uuid())
  number         String   @unique
  city           String
  driverName     String   @default("")
  driverPhone    String   @default("")
  carNumber      String   @default("")
  deliveryCost   String   @default("")
  requestIds     String
  companyId      String?
  status         String   @default("created")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}