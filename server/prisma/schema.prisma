generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int       @id @default(autoincrement())
  email             String    @unique
  password          String
  plainPassword     String?
  name              String
  role              String    @default("MANAGER")
  // ТЗ: Частное лицо — отдельная роль, привязка к компании
  assignedCompanyId String?
  contactPhone      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  requests          Request[]
}

model Company {
  id             String    @id @default(uuid())
  name           String
  bin            String    @unique
  address        String
  factAddress    String    @default("")
  phone          String    @default("")
  director       String    @default("")
  email          String    @default("")
  bank           String    @default("")
  bik            String    @default("")
  account        String    @default("")
  kbe            String    @default("")
  bankDetails    String    @default("")
  managerDetails String    @default("")
  // ТЗ: Компании — поле для PNG с печатью и подписью
  stamp          String?
 // ТЗ: Организации — нельзя удалять, только аннулировать
  status         String    @default("active")
  // ТЗ: ставка налога в % (для расчёта расхода "Налоги"), 0 = нет налога
  taxRate        Float     @default(0)
  // ТЗ: налоговый режим компании: 'none' | 'simplified' | 'our'
  //   simplified (упрощёнка): налог = оборот × (taxRate% + taxExtra%)
  //   our (ОУР с НДС): используется vatRate; точная формула — по данным бухгалтера
  taxMode        String    @default("none")
  // Доп. сбор % (напр. 1% за снятие наличных у TASU KZ) — для упрощёнки
  taxExtra       Float     @default(0)
  // Ставка НДС % (для режима ОУР)
  vatRate        Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  logo           String?
  requests       Request[]
}

model Request {
  id          String    @id @default(uuid())
  status      String    @default("Заявка")
  date        String
  companyId   String
  managerId   Int
  type        String    @default("REQUEST")
  route       String?
  cargo       String?
  docNumber   String?   @unique
  totalSum    String?   @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
  details     String?
  // ТЗ: Аналитика — фильтр по оплачено/неоплачено
  isPaid                  Boolean   @default(false)
  paidAt                  DateTime?
  // ТЗ: Бухгалтер — финальное завершение работы
  isFullyCompleted        Boolean   @default(false)
  fullyCompletedAt        DateTime?
  // ТЗ: Бухгалтер — если отредактировали после завершения, должна попасть в сток как новая
  reEditedAfterCompletion Boolean   @default(false)
  company     Company  @relation(fields: [companyId], references: [id])
  manager     User     @relation(fields: [managerId], references: [id])

  @@index([status])
  @@index([companyId])
  @@index([type])
  @@index([isPaid])
  @@index([isFullyCompleted])
}

model Contract {
  id               String   @id @default(uuid())
  number           String
  date             String
  type             String
  role             String?
  status           String   @default("active")
  companyId        String
  companyName      String?
  customerName     String?
  actId            String?
  details          String?
  counterpartyId   String?
  directorName     String?
  directorPosition String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Counterparty {
  id           String   @id @default(uuid())
  name         String
  phone        String   @default("")
  email        String   @default("")
  companyName  String   @default("")
  bin          String   @default("")
  address      String   @default("")
  bank         String   @default("")
  bik          String   @default("")
  account      String   @default("")
  kbe          String   @default("")
  director     String   @default("")
  // ТЗ: Контрагенты — добавить контактный номер
  contactPhone String?  @default("")
  companyId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Expense {
  id          String   @id @default(uuid())
  date        String
  category    String
  description String   @default("")
  amount      Float
  docNumber   String   @default("")
  // ТЗ: Расход на существующую накладную (по умолчанию категория "Перевозка")
  requestId   String?
  companyId   String?
  userId      Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([requestId])
}

model Tariff {
  id            String   @id @default(uuid())
  city          String   @unique
  pricePerKg    Float    @default(0)
  deliveryPrice Float    @default(0)
  // ТЗ: Тарифы частных лиц — диапазоны (до 10, до 20, до 30, до 80, до 150, до 300, до 600 кг)
  weightRanges  Json?
  // ТЗ: Возможность добавить доп. сумму к тарифу частного лица
  extraSum      Float    @default(0)
  // Пометка что тариф для частных лиц
  isPrivate     Boolean  @default(false)
  companyId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Batch {
  id           String    @id @default(uuid())
  number       String    @unique
  city         String
  driverName   String    @default("")
  driverPhone  String    @default("")
  carNumber    String    @default("")
  deliveryCost String    @default("")
  requestIds   String
  companyId    String?
  status       String    @default("created")
  // ТЗ: Партии — Активные / Сформированные
  isFormed     Boolean   @default(false)
  formedAt     DateTime?
  // Сохранённая ведомость (HTML/JSON для печати)
  vedomostData String?
  totalSeats   Int       @default(0)
  totalWeight  Float     @default(0)
  // Партия: перевозчик / представитель / грузчики из справочников
  carrierId        String?
  representativeId String?
  loadersCount     Int       @default(0)
  // ТЗ: партия может входить только в ОДНУ ведомость перевозчика одновременно
  carrierVedomostId String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([isFormed])
}

model Carrier {
  id        String   @id @default(uuid())
  name      String
  phone     String   @default("")
  city      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Representative {
  id        String   @id @default(uuid())
  name      String
  phone     String   @default("")
  city      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ТЗ: Ведомость перевозчика — формируется ТОЛЬКО из уже сформированных партий
// (не напрямую из накладных), содержит авторасчёт сумм для перевозчика,
// грузчиков и представителя по тарифам из справочника Тарифы
model CarrierVedomost {
  id                String   @id @default(uuid())
  number            String   @unique
  companyId         String?
  // JSON-массив id партий (Batch), из которых сформирована ведомость
  batchIds          String
  // JSON-снэпшот: разбивка по каждой партии (город, вес, тарифы, суммы) — для печати
  data              String
  totalWeight       Float    @default(0)
  carrierSum        Float    @default(0)
  loaderSum         Float    @default(0)
  representativeSum Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}